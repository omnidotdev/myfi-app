{
  "name": "@omnidotdev/myfi-app",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently --names \"GQL,VITE\" -c \"magenta,cyan\" \"bun run graphql:generate:watch\" \"bun dev:vite\"",
    "dev:vite": "bun --env-file .env.local --env-file .env.development vite dev",
    "build": "tsc --noEmit && vite build",
    "start": "node .output/server/index.mjs",
    "check": "biome check .",
    "format": "biome format --write .",
    "lint": "biome check --write .",
    "graphql:generate": "graphql-codegen --config src/lib/graphql/codegen.config.ts",
    "graphql:generate:watch": "bun graphql:generate -w",
    "knip": "knip",
    "test": "bun test",
    "prepare": "husky"
  },
  "dependencies": {
    "@ark-ui/react": "^5.34.0",
    "@graphql-typed-document-node/core": "^3.2.0",
    "@internationalized/date": "^3.10.1",
    "@omnidotdev/providers": "github:omnidotdev/providers#b49cf2e",
    "@tanstack/react-form": "^1.28.0",
    "@tanstack/react-query": "^5.90.0",
    "@tanstack/react-router": "^1.163.0",
    "@tanstack/react-router-ssr-query": "^1.163.0",
    "@tanstack/react-start": "^1.166.0",
    "@tanstack/react-table": "^8.21.0",
    "@tanstack/zod-adapter": "^1.163.0",
    "better-auth": "^1.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.19",
    "graphql": "^16.13.0",
    "graphql-request": "^7.4.0",
    "jose": "^6.1.0",
    "lucide-react": "^0.562.0",
    "ms": "^2.1.3",
    "papaparse": "^5.5.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-plaid-link": "^4.1.1",
    "recharts": "^2.15.0",
    "sonner": "^2.0.0",
    "tailwind-merge": "^3.5.0",
    "ts-pattern": "^5.9.0",
    "usehooks-ts": "^3.1.1",
    "zod": "^4.3.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.11",
    "@graphql-codegen/cli": "^5.0.0",
    "@graphql-codegen/client-preset": "^4.0.0",
    "@graphql-codegen/import-types-preset": "^3.0.0",
    "@graphql-codegen/typescript-graphql-request": "^6.4.0",
    "@graphql-codegen/typescript-react-query": "^6.0.0",
    "@tailwindcss/vite": "^4.2.0",
    "@tanstack/nitro-v2-vite-plugin": "^1.154.0",
    "@tanstack/react-devtools": "^0.9.0",
    "@tanstack/react-query-devtools": "^5.90.0",
    "@tanstack/react-router-devtools": "^1.163.0",
    "@types/ms": "^2.0.0",
    "@types/papaparse": "^5.3.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.1.0",
    "concurrently": "^9.2.0",
    "dotenv-cli": "^11.0.0",
    "husky": "^9.1.0",
    "knip": "^5.85.0",
    "tailwindcss": "^4.2.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.0",
    "vite": "^7.3.0",
    "vite-plugin-mkcert": "^1.17.0",
    "vite-tsconfig-paths": "^6.1.0"
  },
  "trustedDependencies": [
    "@parcel/watcher",
    "@tailwindcss/oxide",
    "esbuild",
    "oxc-resolver",
    "sharp"
  ],
  "overrides": {
    "@internationalized/date": "^3.10.1"
  }
}
